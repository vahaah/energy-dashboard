# ─── Tinybird ────────────────────────────────────────────────
# Get these from https://app.tinybird.co → your workspace → Tokens
# After deploying Tinybird resources: cd tinybird && tb --cloud deploy
# Then list tokens: tb --cloud token ls
TINYBIRD_URL=https://api.eu-central-1.aws.tinybird.co
TINYBIRD_TOKEN=your_admin_token_here
TINYBIRD_READ_TOKEN=your_dashboard_read_token_here

# ─── EIA (US Energy Information Administration) ──────────────
# Register at https://www.eia.gov/opendata/ — free, instant
# DEMO_KEY works but has lower rate limits (30 req/hr)
EIA_API_KEY=DEMO_KEY

# ─── Vercel Cron Secret ─────────────────────────────────────
# Set in Vercel dashboard → Settings → Environment Variables
# Vercel automatically sends this as Authorization: Bearer <secret>
CRON_SECRET=your_random_secret_here

# ─── Upstash Redis (production rate limiting) ────────────────
# Sign up free at https://console.upstash.com
# Create a Redis database → copy REST URL and REST Token
# Without these, rate limiting uses an in-memory store (resets on cold start)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
